<UserControl x:Class="Gaze.Controls.EyeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="14" Height="18">
    <Canvas x:Name="EyeCanvas" Width="14" Height="18" ClipToBounds="True">
        <!-- Eye socket (white capsule) -->
        <Rectangle x:Name="EyeSocket" 
                   Canvas.Left="0" Canvas.Top="0"
                   Width="14" Height="18" 
                   RadiusX="7" RadiusY="9" 
                   Fill="White">
            <Rectangle.RenderTransform>
                <ScaleTransform x:Name="EyeScaleTransform" ScaleX="1" ScaleY="1" CenterX="7" CenterY="9"/>
            </Rectangle.RenderTransform>
        </Rectangle>

        <!-- Pupil group (clipped by eye shape) -->
        <Canvas x:Name="PupilCanvas" Width="14" Height="18" ClipToBounds="True">
            <Canvas.Clip>
                <RectangleGeometry Rect="0,0,14,18" RadiusX="7" RadiusY="9"/>
            </Canvas.Clip>
            
            <!-- Dark pupil circle -->
            <Ellipse x:Name="Pupil" 
                     Width="9" Height="9" 
                     Fill="#1F1F1F"
                     Canvas.Left="2.5" Canvas.Top="4.5">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="PupilTranslate" X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            
            <!-- White highlight dot -->
            <Ellipse x:Name="Highlight" 
                     Width="3" Height="3" 
                     Fill="White"
                     Canvas.Left="1" Canvas.Top="2.5">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="HighlightTranslate" X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            
            <!-- Emoji overlay (hidden by default) -->
            <TextBlock x:Name="EmojiText" 
                       FontSize="12" 
                       Canvas.Left="-1" Canvas.Top="0"
                       Visibility="Collapsed">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="EmojiTranslate" X="0" Y="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>
        
        <!-- Sleep curve (smile arc shown when sleeping) -->
        <Path x:Name="SleepCurve" 
              Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Data="M 1,3 Q 7,9 13,3"
              Canvas.Left="0" Canvas.Top="10"
              Opacity="0"/>
    </Canvas>
</UserControl>
