<Window x:Class="Gaze.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Gaze.Controls"
        WindowStyle="None" AllowsTransparency="True"
        WindowState="Maximized" Topmost="True"
        ShowInTaskbar="False" Background="Transparent"
        Title="Welcome to Gaze"
        KeyDown="Window_KeyDown">
    <Grid x:Name="RootGrid">
        <!-- Dark translucent background -->
        <Border x:Name="BackdropBorder" Background="#E8000000"/>
        
        <!-- Bottom glow effect -->
        <Canvas x:Name="GlowCanvas" IsHitTestVisible="False">
            <Ellipse x:Name="GlowEllipse" 
                     Width="1200" Height="600"
                     Opacity="0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#E6FFFFFF" Offset="0"/>
                        <GradientStop Color="#B37C3AED" Offset="0.4"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="GlowScale" ScaleX="0.1" ScaleY="0.1" CenterX="600" CenterY="300"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>
        
        <!-- Center content -->
        <StackPanel x:Name="ContentPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- App icon -->
            <Border x:Name="LogoBorder" Width="120" Height="120" CornerRadius="28" 
                    Background="#7C3AED" HorizontalAlignment="Center" Margin="0,0,0,24"
                    Opacity="0">
                <Border.Effect>
                    <DropShadowEffect Color="#7C3AED" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>
                <Image Source="../icon.png" Width="80" Height="80" RenderOptions.BitmapScalingMode="HighQuality"/>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="0.8" ScaleY="0.8" CenterX="60" CenterY="60"/>
                </Border.RenderTransform>
            </Border>
            
            <!-- Welcome text -->
            <TextBlock x:Name="WelcomeText" 
                       Text="WELCOME TO GAZE" 
                       FontSize="52" FontWeight="ExtraBold"
                       Foreground="White" HorizontalAlignment="Center"
                       Opacity="0"
                       FontFamily="Segoe UI Variable Display, Segoe UI">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#7C3AED" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="TextScale" ScaleX="0.95" ScaleY="0.95" 
                                    CenterX="250" CenterY="30"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            
            <!-- Enter button -->
            <Border x:Name="EnterBorder" Margin="0,32,0,0" HorizontalAlignment="Center"
                    CornerRadius="20" BorderBrush="#80FFFFFF" BorderThickness="1"
                    Background="#0DFFFFFF" Cursor="Hand" Opacity="0"
                    MouseLeftButtonUp="Enter_Click">
                <TextBlock Text="Enter" FontSize="18" FontWeight="Medium"
                           Foreground="White" Padding="40,10"
                           FontFamily="Segoe UI Variable, Segoe UI"/>
            </Border>
        </StackPanel>
        
        <!-- Cinematic Dynamic Island reveal at top -->
        <Canvas x:Name="IslandRevealCanvas" IsHitTestVisible="False">
            <!-- The Dynamic Island pill that drops in -->
            <Border x:Name="IslandShape" 
                    Width="12" Height="12" 
                    CornerRadius="6" Background="Black"
                    Canvas.Top="-20" Opacity="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
                
                <!-- Content inside the island (eyes + timer) -->
                <Grid x:Name="IslandContent" Opacity="0" ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Eyes -->
                    <StackPanel x:Name="RevealEyes" Grid.Column="0" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <local:EyeControl x:Name="RevealLeftEye"/>
                        <local:EyeControl x:Name="RevealRightEye" Margin="8,0,0,0"/>
                    </StackPanel>
                    
                    <!-- Timer text -->
                    <TextBlock x:Name="RevealTimerText" Grid.Column="2"
                               Text="25:00" FontSize="14" FontWeight="SemiBold"
                               Foreground="#CCFFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable, Segoe UI"/>
                </Grid>
            </Border>
        </Canvas>
    </Grid>
</Window>
