<Window x:Class="Gaze.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gaze Settings" Width="680" Height="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="../icon.png"
        Background="#0F0F0F"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Window.Resources>
        <!-- Typography -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
        </Style>
        
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
        </Style>
        
        <Style x:Key="SettingDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        
        <!-- Glass card -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#1F1F23"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Animated toggle switch -->
        <Style TargetType="ToggleButton" x:Key="ModernToggle">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="44" Height="24">
                            <Border x:Name="Track" CornerRadius="12"
                                    Background="#333333">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="Thumb" Width="20" Height="20" CornerRadius="10"
                                    Background="#EEEEEE" HorizontalAlignment="Left"
                                    Margin="2,2,0,2">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#7C3AED"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,2,2,2"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Stepper button style -->
        <Style x:Key="StepperBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="#252528" 
                                BorderBrush="#333" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#333338"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Sidebar nav button template -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBg" CornerRadius="8" Padding="12,9" Margin="8,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="#1F1F23"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="10" Padding="20,10"
                                Background="#7C3AED">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#5B21B6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Column="0" Background="#111113" BorderBrush="#1A1A1E" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
                    <!-- Brand header -->
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,20">
                        <Border Width="40" Height="40" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Image Source="../icon.png" Width="26" Height="26" 
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Gaze" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="VersionLabel" Text="v1.0.1" FontSize="10" Foreground="#555555"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Height="1" Background="#1A1A1E" Margin="16,0,16,12"/>
                    
                    <!-- Navigation -->
                    <TextBlock Text="SETTINGS" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#444" Margin="22,0,0,6"/>
                    
                    <Button x:Name="GeneralTab" Content="⚙  General" Click="Tab_Click" Tag="General"
                            Style="{StaticResource NavButton}" Foreground="White"/>
                    <Button x:Name="TimerTab" Content="⏱  Timer" Click="Tab_Click" Tag="Timer"
                            Style="{StaticResource NavButton}"/>
                    <Button x:Name="InteractionTab" Content="👁  Interaction" Click="Tab_Click" Tag="Interaction"
                            Style="{StaticResource NavButton}"/>
                    
                    <Border Height="1" Background="#1A1A1E" Margin="16,12,16,12"/>
                    
                    <TextBlock Text="APP" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#444" Margin="22,0,0,6"/>
                    
                    <Button x:Name="UpdatesTab" Content="⬆  Updates" Click="Tab_Click" Tag="Updates"
                            Style="{StaticResource NavButton}"/>
                </StackPanel>
                
                <!-- Bottom: shortcuts hint -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,16" CornerRadius="8" 
                        Background="#18181B" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="SHORTCUTS" FontSize="9" FontWeight="SemiBold" 
                                   Foreground="#444" Margin="0,0,0,4"/>
                        <TextBlock FontSize="10" Foreground="#666">
                            <Run Text="Ctrl+Alt+P" Foreground="#7C3AED" FontWeight="SemiBold"/>
                            <Run Text="  Toggle Timer"/>
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="#666">
                            <Run Text="Shift+Ctrl+P" Foreground="#7C3AED" FontWeight="SemiBold"/>
                            <Run Text="  Show Island"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>
        
        <!-- ═══ Content Area ═══ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" 
                      Margin="24,20,24,20">
          <Grid>
            <!-- ── General Tab ── -->
            <StackPanel x:Name="GeneralPanel">
                <TextBlock Text="STARTUP" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SettingCard}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Launch at Login" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="Automatically start Gaze when you sign in." 
                                       Style="{StaticResource SettingDescription}"/>
                        </StackPanel>
                        <ToggleButton x:Name="LaunchToggle" Style="{StaticResource ModernToggle}" 
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Click="Toggle_Changed"/>
                    </Grid>
                </Border>
                
                <TextBlock Text="EFFECTS" Style="{StaticResource SectionTitle}" Margin="0,8,0,8"/>
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="UI Micro-sounds" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Play subtle sound effects during interactions." 
                                           Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                            <ToggleButton x:Name="SoundToggle" Style="{StaticResource ModernToggle}" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Click="Toggle_Changed"/>
                        </Grid>
                        <Border Height="1" Background="#1F1F23" Margin="-16,0,-16,14"/>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Hide on Inactivity" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Automatically hide the island when not in use." 
                                           Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                            <ToggleButton x:Name="HideToggle" Style="{StaticResource ModernToggle}" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Click="Toggle_Changed"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- ── Timer Tab ── -->
            <StackPanel x:Name="TimerPanel" Visibility="Collapsed">
                <TextBlock Text="POMODORO CONFIGURATION" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Work Session" Style="{StaticResource SettingLabel}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border CornerRadius="6" Background="#252528" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock x:Name="WorkValue" Foreground="#A78BFA" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                                <Button Content="−" Click="WorkMinus_Click" Style="{StaticResource StepperBtn}"/>
                                <Button Content="+" Click="WorkPlus_Click" Style="{StaticResource StepperBtn}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Background="#1F1F23" Margin="-16,0,-16,14"/>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Break Session" Style="{StaticResource SettingLabel}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border CornerRadius="6" Background="#252528" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock x:Name="BreakValue" Foreground="#34D399" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                                <Button Content="−" Click="BreakMinus_Click" Style="{StaticResource StepperBtn}"/>
                                <Button Content="+" Click="BreakPlus_Click" Style="{StaticResource StepperBtn}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Background="#1F1F23" Margin="-16,0,-16,14"/>
                        <Grid>
                            <TextBlock Text="Pomodoro Loops" Style="{StaticResource SettingLabel}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border CornerRadius="6" Background="#252528" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock x:Name="CyclesValue" Foreground="#FBBF24" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                                <Button Content="−" Click="CyclesMinus_Click" Style="{StaticResource StepperBtn}"/>
                                <Button Content="+" Click="CyclesPlus_Click" Style="{StaticResource StepperBtn}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- ── Interaction Tab ── -->
            <StackPanel x:Name="InteractionPanel" Visibility="Collapsed">
                <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource SettingCard}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Track Cursor" Style="{StaticResource SettingLabel}"/>
                            <TextBlock Text="The eyes will follow your mouse movement." 
                                       Style="{StaticResource SettingDescription}"/>
                        </StackPanel>
                        <ToggleButton x:Name="CursorToggle" Style="{StaticResource ModernToggle}" 
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Click="Toggle_Changed"/>
                    </Grid>
                </Border>
                
                <TextBlock Text="PERIODIC PEEK" Style="{StaticResource SectionTitle}" Margin="0,8,0,8"/>
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Enabled" Style="{StaticResource SettingLabel}"/>
                                <TextBlock Text="Briefly show the island at regular intervals." 
                                           Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                            <ToggleButton x:Name="PeekToggle" Style="{StaticResource ModernToggle}" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Click="Toggle_Changed"/>
                        </Grid>
                        <Grid x:Name="PeekIntervalRow" Visibility="Collapsed" Margin="0,6,0,0">
                            <Border Height="1" Background="#1F1F23" Margin="-16,0,-16,12" VerticalAlignment="Top"/>
                            <Grid Margin="0,16,0,0">
                                <TextBlock Text="Peek Every" Style="{StaticResource SettingLabel}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Background="#252528" Padding="10,4" Margin="0,0,8,0">
                                        <TextBlock x:Name="PeekValue" Foreground="#A78BFA" FontSize="13" FontWeight="SemiBold"/>
                                    </Border>
                                    <Button Content="−" Click="PeekMinus_Click" Style="{StaticResource StepperBtn}"/>
                                    <Button Content="+" Click="PeekPlus_Click" Style="{StaticResource StepperBtn}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- ── Updates Tab ── -->
            <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                <TextBlock Text="SOFTWARE UPDATES" Style="{StaticResource SectionTitle}"/>
                
                <!-- Current version card -->
                <Border Style="{StaticResource SettingCard}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Current Version" Style="{StaticResource SettingLabel}"/>
                            <TextBlock x:Name="CurrentVersionText" Text="v1.0.1" FontSize="22" FontWeight="Bold"
                                       Foreground="#A78BFA" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button x:Name="CheckUpdateBtn" Content="Check for Updates" 
                                Style="{StaticResource PrimaryBtn}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="CheckUpdate_Click"/>
                    </Grid>
                </Border>
                
                <!-- Status card (shown after checking) -->
                <Border x:Name="UpdateStatusCard" Style="{StaticResource SettingCard}" Visibility="Collapsed">
                    <StackPanel>
                        <!-- Checking spinner -->
                        <StackPanel x:Name="CheckingStatus" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="⟳" FontSize="16" Foreground="#A78BFA" Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Checking for updates…" Style="{StaticResource SettingLabel}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Up to date -->
                        <StackPanel x:Name="UpToDateStatus" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="✓" FontSize="18" Foreground="#34D399" FontWeight="Bold" 
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="You're running the latest version!" 
                                       Style="{StaticResource SettingLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Update available -->
                        <StackPanel x:Name="UpdateAvailableStatus" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⬆" FontSize="16" Foreground="#FBBF24" Margin="0,0,8,0" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Style="{StaticResource SettingLabel}" VerticalAlignment="Center">
                                    <Run Text="Version "/>
                                    <Run x:Name="NewVersionText" Text="" Foreground="#FBBF24" FontWeight="Bold"/>
                                    <Run Text=" is available!"/>
                                </TextBlock>
                            </StackPanel>
                            
                            <!-- Release notes -->
                            <Border CornerRadius="8" Background="#111113" Padding="12" Margin="0,0,0,12"
                                    MaxHeight="120">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" 
                                               FontSize="11" Foreground="#888" LineHeight="18"/>
                                </ScrollViewer>
                            </Border>
                            
                            <Grid>
                                <Button x:Name="InstallUpdateBtn" Content="Download &amp; Install" 
                                        Style="{StaticResource PrimaryBtn}"
                                        HorizontalAlignment="Left"
                                        Click="InstallUpdate_Click"/>
                                <!-- Progress bar -->
                                <StackPanel x:Name="DownloadProgress" Orientation="Horizontal" 
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Border Width="140" Height="6" CornerRadius="3" Background="#252528">
                                        <Border x:Name="ProgressFill" CornerRadius="3" HorizontalAlignment="Left"
                                                Width="0" Height="6">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                    <GradientStop Color="#A855F7" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                    <TextBlock x:Name="ProgressText" Text="0%" FontSize="11" 
                                               Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Error -->
                        <StackPanel x:Name="ErrorStatus" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="✕" FontSize="16" Foreground="#EF4444" FontWeight="Bold" 
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ErrorText" Style="{StaticResource SettingLabel}" 
                                       Foreground="#EF4444" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- GitHub info card -->
                <Border Style="{StaticResource SettingCard}" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="Updates are pulled from GitHub Releases." 
                                   Style="{StaticResource SettingDescription}"/>
                        <TextBlock FontSize="11" Foreground="#555" Margin="0,4,0,0">
                            <Run Text="Repository: "/>
                            <Run Text="AtharvaBari/Gaze" Foreground="#7C3AED" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>
    </Grid>
</Window>
